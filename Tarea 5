#include <stdio.h>
#include <ctype.h>

int main() {
    char cad[50];
    int i, may=0, min=0, otros=0;

    gets(cad);

    for(i=0; cad[i]; i++){
        if(isupper(cad[i])) may++;
        else if(islower(cad[i])) min++;
        else otros++;
    }

    printf("Mayus: %d\nMinus: %d\nOtros: %d", may, min, otros);
}

