int main() {
    char cad1[50], cad2[50];
    char *p1, *p2;

    printf("Cadena 1: ");
    gets(cad1);
    printf("Cadena 2: ");
    gets(cad2);

    p1 = strtok(cad1, " ");
    p2 = strtok(cad2, " ");

    while(p1 != NULL || p2 != NULL) {
        if(p1 != NULL){
            printf("%s ", p1);
            p1 = strtok(NULL, " ");
        }
        if(p2 != NULL){
            printf("%s ", p2);
            p2 = strtok(NULL, " ");
        }
    }
    return 0;
}

#include <stdio.h>
#include <string.h>

int main() {
    char cad[50], *palabras[20];
    int i = 0, j;

    printf("Ingrese cadena: ");
    gets(cad);

    palabras[i] = strtok(cad, " ");
    while(palabras[i] != NULL) {
        i++;
        palabras[i] = strtok(NULL, " ");
    }

    for(j = i-1; j >= 0; j--)
        printf("%s ", palabras[j]);

    return 0;
}

