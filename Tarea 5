#include <stdio.h>
#include <string.h>

int contarVocales(char *cad) {
    int i, c=0;
    for(i=0; cad[i]; i++)
        if(strchr("aeiouAEIOU", cad[i]))
            c++;
    return c;
}

int main() {
    char ARC[10][50];
    int i, max=0, pos=0;

    for(i=0;i<10;i++) {
        gets(ARC[i]);
        int v = contarVocales(ARC[i]);
        if(v > max){
            max = v;
            pos = i;
        }
    }

    printf("Mayor: %s", ARC[pos]);
}

