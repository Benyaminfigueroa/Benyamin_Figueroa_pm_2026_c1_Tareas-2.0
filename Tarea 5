void ventasTotales(vendedor A[], int n) {
    for (int i = 0; i < n; i++) {
        float suma = 0;
        for (int j = 0; j < 12; j++)
            suma += A[i].ven[j];

        printf("\nVendedor %d - Total: %.2f", A[i].num, suma);
    }
}

void incremento(vendedor A[], int n) {
    for (int i = 0; i < n; i++) {
        float suma = 0;
        for (int j = 0; j < 12; j++)
            suma += A[i].ven[j];

        if (suma > 1500000) {
            A[i].sal *= 1.05;
            printf("\nVendedor %d nuevo salario: %.2f", A[i].num, A[i].sal);
        }
    }
}

void ventasBajas(vendedor A[], int n) {
    for (int i = 0; i < n; i++) {
        float suma = 0;
        for (int j = 0; j < 12; j++)
            suma += A[i].ven[j];

        if (suma < 300000) {
            printf("\n%d %s %.2f", A[i].num, A[i].nom, suma);
        }
    }
}

void procesar(producto A[], int n) {
    char ope;
    int cla, can;

    printf("Operacion (C/V, 0 para salir): ");
    scanf(" %c", &ope);

    while (ope != '0') {
        scanf("%d %d", &cla, &can);

        int pos = buscar(A, n, cla);

        if (pos != -1) {
            if (ope == 'C')
                A[pos].existencia += can;
            else if (ope == 'V') {
                if (A[pos].existencia >= can)
                    A[pos].existencia -= can;
                else
                    printf("Stock insuficiente\n");
            }
        }

        printf("Operacion: ");
        scanf(" %c", &ope);
    }
}

float promedioAlumno(alumno a) {
    float suma = 0;
    for (int i = 0; i < MAT; i++)
        suma += a.cal[i].promedio;

    return suma / MAT;
}

void listar(alumno A[], int n, char nivel[], int grado, char salon[]) {
    for (int i = 0; i < n; i++) {
        if (strcmp(A[i].nivel.nivel, nivel) == 0 &&
            A[i].nivel.grado == grado &&
            strcmp(A[i].nivel.salon, salon) == 0) {

            printf("\n%d %s %.2f",
                A[i].matricula,
                A[i].nombre,
                promedioAlumno(A[i]));
        }
    }
}

void mejorAlumno(alumno A[], int n, char nivel[], int grado, char salon[]) {
    float mejor = -1;
    int pos = -1;

    for (int i = 0; i < n; i++) {
        if (strcmp(A[i].nivel.nivel, nivel) == 0 &&
            A[i].nivel.grado == grado &&
            strcmp(A[i].nivel.salon, salon) == 0) {

            float prom = promedioAlumno(A[i]);

            if (prom > mejor) {
                mejor = prom;
                pos = i;
            }
        }
    }

    if (pos != -1) {
        printf("\nMejor alumno:");
        printf("\n%d %s %.2f",
            A[pos].matricula,
            A[pos].nombre,
            mejor);
    }
}
