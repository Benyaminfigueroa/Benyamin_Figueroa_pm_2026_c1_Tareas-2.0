int contarPalabras(char *cad){
    int i=0, c=0;

    while(cad[i]){
        if(cad[i]==' ' && cad[i+1]!=' ')
            c++;
        i++;
    }
    return c+1;
}

#include <stdio.h>
#include <string.h>

int main(){
    char ARC[20][80];
    int freq[20]={0};
    int i;

    for(i=0;i<20;i++){
        gets(ARC[i]);
        char *p = strtok(ARC[i], " ");
        while(p){
            freq[strlen(p)]++;
            p = strtok(NULL," ");
        }
    }

    for(i=1;i<20;i++)
        printf("%d -> %d\n", i, freq[i]);
}


